# Admin login for the /admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing secret. Use a long random string in production.
JWT_SECRET=please-change-this-to-a-long-random-string

# Postgres connection string (Neon, Supabase, RDS, etc.)
# On Vercel, this is set automatically when you provision a Neon database via Storage.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudinary credentials. Required for production / Vercel deployment.
# When unset, uploads fall back to the local ./uploads/ directory (handy for dev).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: upload folder name in Cloudinary (defaults to "irvan-photos")
# CLOUDINARY_FOLDER=irvan-photos

# Optional: HTTP port (default 3000)
PORT=3000

# Optional: max upload size in MB (default 25)
MAX_UPLOAD_MB=25
