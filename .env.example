# Admin login for the /admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Used to sign JWT session tokens. Use a long random string in production.
JWT_SECRET=please-change-this-to-a-long-random-string

# Optional: HTTP port (default 3000)
PORT=3000

# Optional: max upload size in MB (default 25)
MAX_UPLOAD_MB=25
